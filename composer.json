{
  "name": "webdevartisan/lexicon",
  "description": "Lexicon - Modern PHP Blog Framework",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": "^8.3",
    "doctrine/inflector": "^2.1",
    "phpmailer/phpmailer": "^7.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24",
    "infection/infection": "^0.32.3",
    "laravel/pint": "^1.27",
    "mockery/mockery": "^1.6",
    "pestphp/pest": "^3.8",
    "pestphp/pest-plugin": "^3.0",
    "pestphp/pest-plugin-faker": "^3.0",
    "phpstan/phpstan": "*",
    "phpstan/phpstan-strict-rules": "*",
    "symfony/var-dumper": "^7.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/App/",
      "Framework\\": "src/Framework/"
    },
    "files": [
      "src/Framework/Core/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php -r \"! is_dir('storage/cache') && mkdir('storage/cache', 0755, true);\"",
      "@php -r \"! is_dir('storage/logs') && mkdir('storage/logs', 0755, true);\"",
      "@php -r \"! is_dir('storage/uploads') && mkdir('storage/uploads', 0755, true);\""
    ],
    "post-create-project-cmd": [
      "@setup"
    ],
    "setup": [
      "Composer\\Config::disableProcessTimeout",
      "@composer install --optimize-autoloader",
      "@php -r \"if (!file_exists('.env')) { echo '⚠️  Run install.bat (Windows) or install.sh (Linux/macOS) for first-time setup\\n'; exit(1); }\"",
      "@php scripts/setup/setup.php"
    ],
    "setup:quick": [
      "@composer install --no-dev --optimize-autoloader",
      "@php scripts/setup/setup.php"
    ],
    "fresh": [
      "@php cli db:fresh",
      "@php cli db:seed"
    ],
    "cache:clear": [
      "@php cli cache:clear"
    ],
    "cache:warm": [
      "@php cli cache:warm"
    ],
    "test": [
        "@php tests/setup-test-db.php",
        "vendor/bin/pest"
    ],
    "test:unit": [
        "vendor/bin/pest --testsuite=Unit"
    ],
    "test:integration": [
        "@php tests/setup-test-db.php",
        "vendor/bin/pest --testsuite=Integration"
    ],
    "test:feature": [
        "@php tests/setup-test-db.php",
        "vendor/bin/pest --testsuite=Feature"
    ],
    "test:coverage": [
        "@php tests/setup-test-db.php",
        "vendor/bin/pest --coverage --min=25"
    ],
    "test:fast": [
        "vendor/bin/pest --testsuite=Unit --parallel"
    ],
    "test:slow": [
        "@php tests/setup-test-db.php",
        "vendor/bin/pest --testsuite=Integration --testsuite=Feature"
    ],
    "test:watch": [
        "vendor/bin/pest --watch"
    ],
    "test:coverage-html": [
        "@php tests/setup-test-db.php",
        "vendor/bin/pest --coverage-html=storage/coverage"
    ],
    "test:parallel": [
        "@php tests/setup-test-db.php",
        "vendor/bin/pest --parallel"
    ],
    "analyse": [
      "./vendor/bin/phpstan analyse --memory-limit=512M"
    ],
    "analyse:baseline": [
      "./vendor/bin/phpstan analyse --memory-limit=512M --generate-baseline"
    ],
    "infection": [
      "./vendor/bin/infection --threads=4"
    ],
    "deploy": [
      "@composer install --no-dev --optimize-autoloader --no-interaction",
      "@php cli cache:clear",
      "@php cli cache:warm"
    ],
    "format": "./vendor/bin/pint",
    "format:check": "./vendor/bin/pint --test"
  },
  "scripts-descriptions": {
    "setup": "Run first-time installation (requires .env file)",
    "setup:quick": "Quick setup for production (no dev dependencies)",
    "fresh": "Reset database and reseed",
    "cache:clear": "Clear all application caches",
    "cache:warm": "Warm up application caches",
    "test": "Run all tests",
    "test:unit": "Run only unit tests (fast, parallel)",
    "test:integration": "Run only integration tests (with database)",
    "test:feature": "Run only feature tests (full HTTP cycle)",
    "test:coverage": "Run tests with code coverage report",
    "test:coverage-html": "Generate HTML coverage report",
    "test:fast": "Run only fast unit tests",
    "test:slow": "Run slow integration and feature tests",
    "test:watch": "Watch mode - rerun tests on file changes",
    "test:parallel": "Run tests in parallel for faster execution",
    "analyse": "Run PHPStan static analysis",
    "analyse:baseline": "Generate PHPStan baseline for existing codebase",
    "infection": "Run mutation testing with Infection",
    "deploy": "Deploy application (production-optimized)",
    "format": "Format code using Laravel Pint",
    "format:check": "Check code style without making changes"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "infection/extension-installer": true
    },
    "platform": {
      "php": "8.3"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
